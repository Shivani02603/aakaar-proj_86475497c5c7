# Backend database connection string
DATABASE_URL=postgresql://<username>:<password>@<host>:<port>/<database>

# Secret key for JWT authentication
JWT_SECRET=<random secret>

# Backend port
PORT=8000

# Frontend API URL pointing to the backend
VITE_API_URL=http://localhost:8000

# Directory for file uploads
UPLOAD_DIR=./uploads

# OpenAI API key for embeddings
OPENAI_API_KEY=<your_openai_api_key>

# Google Generative AI SDK key for answering queries
ANTHROPIC_API_KEY=<your_anthropic_api_key>

# Pinecone API key for vector database (if applicable)
PINECONE_API_KEY=<your_pinecone_api_key>

# PostgreSQL URL for pgvector service
POSTGRES_URL=postgresql://<username>:<password>@<host>:<port>/<database>